        "if": { "and": [ { "math": [ "LS_Passcode_Selector", "==", "2" ] }, { "u_has_trait": "LS_Passcode_2" } ] },
        "then": { "math": [ "LS_Passcode_Selector -= 1" ] }
      },
      {
        "if": { "and": [ { "math": [ "LS_Passcode_Selector", "==", "1" ] }, { "u_has_trait": "LS_Passcode_1" } ] },
        "then": { "math": [ "LS_Passcode_Selector -= 1" ] }
      }
    ]
  },
