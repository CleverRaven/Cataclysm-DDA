      { "math": [ "u_ire -= 5" ] }
    ]
  },
  {
    "type": "effect_on_condition",
    "id": "EOC_PORTAL_RADIOSPHERE_RETURN",
    "condition": {
      "and": [
        { "test_eoc": "EOC_PORTAL_STORM_CONDITION_FLAG_DIMENSIONAL_ANCHOR" },
        { "not": "u_driving" },
