    "effect": [
      {
        "if": { "or": [ { "u_at_om_location": "radio_tower_top" }, { "u_at_om_location": "wasp_tower_top" } ] },
        "then": { "run_eocs": "EOC_PORTAL_RADIOSPHERE" }
