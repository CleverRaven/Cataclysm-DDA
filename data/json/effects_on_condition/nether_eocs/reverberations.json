      {
        "if": { "or": [ { "u_at_om_location": "cabin_roof_3" }, { "u_at_om_location": "cabin_roof_3_reverberation_hint" } ] },
        "then": { "run_eocs": "EOC_PORTAL_CABINS" }
      }
    ]
  },
  {
