  {
    "type": "effect_on_condition",
    "id": "bio_change_hair_color",
    "global": false,
    "condition": { "expects_vars": [ "color_id" ] },
    "effect": [
      {
        "if": { "u_has_trait": "artificial_hair_buzzcut" },
        "then": [
          { "u_lose_trait": "artificial_hair_buzzcut" },
          { "u_add_trait": "artificial_hair_buzzcut", "variant": { "context_val": "color_id" } }
        ],
        "else": {
          "if": { "u_has_trait": "artificial_hair_crewcut" },
          "then": [
            { "u_lose_trait": "artificial_hair_crewcut" },
            { "u_add_trait": "artificial_hair_crewcut", "variant": { "context_val": "color_id" } }
          ],
          "else": {
            "if": { "u_has_trait": "artificial_hair_short" },
            "then": [
              { "u_lose_trait": "artificial_hair_short" },
              { "u_add_trait": "artificial_hair_short", "variant": { "context_val": "color_id" } }
            ],
            "else": {
              "if": { "u_has_trait": "artificial_hair_short_no_fringe" },
              "then": [
                { "u_lose_trait": "artificial_hair_short_no_fringe" },
                { "u_add_trait": "artificial_hair_short_no_fringe", "variant": { "context_val": "color_id" } }
              ],
              "else": {
                "if": { "u_has_trait": "artificial_hair_short_over_eye" },
                "then": [
                  { "u_lose_trait": "artificial_hair_short_over_eye" },
                  { "u_add_trait": "artificial_hair_short_over_eye", "variant": { "context_val": "color_id" } }
                ],
                "else": {
                  "if": { "or": [ { "u_has_trait": "artificial_hair_medium" } ] },
                  "then": [
                    { "u_lose_trait": "artificial_hair_medium" },
                    { "u_add_trait": "artificial_hair_medium", "variant": { "context_val": "color_id" } }
                  ],
                  "else": {
                    "if": { "u_has_trait": "artificial_hair_mohawk" },
                    "then": [
                      { "u_lose_trait": "artificial_hair_mohawk" },
                      { "u_add_trait": "artificial_hair_mohawk", "variant": { "context_val": "color_id" } }
                    ],
                    "else": {
                      "if": { "u_has_trait": "artificial_hair_long" },
                      "then": [
                        { "u_lose_trait": "artificial_hair_long" },
                        { "u_add_trait": "artificial_hair_long", "variant": { "context_val": "color_id" } }
                      ],
                      "else": {
                        "if": { "u_has_trait": "artificial_hair_long_mohawk" },
                        "then": [
                          { "u_lose_trait": "artificial_hair_long_mohawk" },
                          { "u_add_trait": "artificial_hair_long_mohawk", "variant": { "context_val": "color_id" } }
                        ],
                        "else": {
                          "if": { "u_has_trait": "artificial_hair_mullet" },
                          "then": [
                            { "u_lose_trait": "artificial_hair_mullet" },
                            { "u_add_trait": "artificial_hair_mullet", "variant": { "context_val": "color_id" } }
                          ],
                          "else": {
                            "if": { "u_has_trait": "artificial_hair_long_over_eye" },
                            "then": [
                              { "u_lose_trait": "artificial_hair_long_over_eye" },
                              {
                                "u_add_trait": "artificial_hair_long_over_eye",
                                "variant": { "context_val": "color_id" }
                              }
                            ],
                            "else": {
                              "if": { "or": [ { "u_has_trait": "artificial_hair_messy" } ] },
                              "then": [
                                { "u_lose_trait": "artificial_hair_messy" },
                                { "u_add_trait": "artificial_hair_messy", "variant": { "context_val": "color_id" } }
                              ],
