    "condition": { "u_has_item": "highland_purple_incense" },
    "effect": [
      { "u_message": "You swing the censer in a wide arc." },
      { "turn_cost": "2 seconds" },
      { "u_consume_item": "highland_purple_incense" },
      { "u_set_field": "fd_purple_incense", "radius": 2 }
    ]
  },
  {
