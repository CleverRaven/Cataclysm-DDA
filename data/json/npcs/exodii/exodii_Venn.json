  {
    "id": "TALK_EXODII_VENN",
    "type": "talk_topic",
    "dynamic_line": "&A very human-like cyborg stands before you.  Its steel frame is perfectly clean, but tarnished and clouded as if it were constantly exposed to harsh chemical cleansers.\n\nIt stares at you, not moving.",
    "responses": [
      {
        "text": "[Motion to your belongings] Can we trade?",
        "condition": {
          "or": [
            { "u_has_trait": "EXODII_BODY_1" },
            { "u_has_trait": "EXODII_BODY_1b" },
            { "u_has_trait": "EXODII_CYBERFRAME_GENERIC" }
          ]
        },
        "effect": "start_trade",
        "topic": "TALK_DONE"
      },
      {
        "text": "[Motion to the surgical bot] Can you help me with CBM surgery?",
        "condition": {
          "or": [
            { "u_has_trait": "EXODII_BODY_1" },
            { "u_has_trait": "EXODII_BODY_1b" },
            { "u_has_trait": "EXODII_CYBERFRAME_GENERIC" }
          ]
        },
        "topic": "TALK_EXODII_VENN_Bionic_Install"
      },
      {
        "text": "[Motion to your bionic limbs] Could you repair my Cyberframe?",
        "condition": {
          "or": [
            { "u_has_trait": "EXODII_BODY_1" },
            { "u_has_trait": "EXODII_BODY_1b" },
            { "u_has_trait": "EXODII_CYBERFRAME_GENERIC" }
          ]
        },
        "topic": "TALK_EXODII_VENN_repair"
      },
      {
        "text": "Good talk, Venn.  See you later.",
        "condition": {
          "or": [
            { "u_has_trait": "EXODII_BODY_1" },
            { "u_has_trait": "EXODII_BODY_1b" },
            { "u_has_trait": "EXODII_CYBERFRAME_GENERIC" }
          ]
        },
        "topic": "TALK_DONE"
      },
      {
        "text": "Well, nevermind, I guess.",
        "condition": {
          "and": [
            { "not": { "u_has_trait": "EXODII_BODY_1" } },
            { "not": { "u_has_trait": "EXODII_BODY_1b" } },
            { "not": { "u_has_trait": "EXODII_CYBERFRAME_GENERIC" } }
          ]
        },
        "topic": "TALK_DONE"
      }
    ]
  },
  {
    "type": "talk_topic",
    "id": "TALK_EXODII_VENN_repair",
    "dynamic_line": "&You sit on the surgical table and Venn pulls an aging CRT into view.  The spider-like surgical robot starts to greedily poke and prod you.  The monitor highlights your needs on a low resolution blueprint of your Cyberframe.",
    "responses": [
      { "text": "[Offer to trade for the repairs]", "effect": "repair_bionic_limbs", "topic": "TALK_DONE" },
      { "text": "Actually, nevermind.", "topic": "TALK_DONE" }
    ]
  },
  {
    "id": "TALK_EXODII_VENN_Bionic_Install",
    "type": "talk_topic",
    "dynamic_line": "&You sit on the surgical table and Venn pulls an aging CRT into view.  The spider-like surgical robot starts to greedily poke and prod you.  The monitor highlights your current bionics, and available upgrades, all accompanied by text you don't understand.",
    "responses": [
      { "text": "[Point to a CBM on the screen to install]", "topic": "TALK_DONE", "effect": "bionic_install" },
      { "text": "[Point to a CBM on the screen to remove]", "topic": "TALK_DONE", "effect": "bionic_remove" }
    ]
