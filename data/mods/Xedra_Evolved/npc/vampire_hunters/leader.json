          "and": [
            { "not": { "u_has_trait": "VAMPIRE" } },
            { "not": { "u_has_mission": "MISSION_VAMPIRE_HUNTER_LEADER_CURE_OR_KILL_TARGET" } },
            { "not": { "compare_string": [ "yes", { "u_val": "completed_hunters_kill_or_cure_target" } ] } },
            { "math": [ "Vampire_Hunter_Quest_Completed == 3" ] },
            { "math": [ "Vampire_Hunter_Quest_Accepted == 3" ] }
          ]
        }
      },
