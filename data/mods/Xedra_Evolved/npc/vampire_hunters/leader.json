  {
    "id": "TALK_VAMPIRE_HUNTER_LEADER_MISSION_CURE_OR_KILL",
    "type": "talk_topic",
    "dynamic_line": "We saw a nearby vampire walk under the sun recently.  Don't worry, they did not burn under the sun thanks to their umbrella.  It means they can be cured, should they accept to.  I will give you a dose of cure and you will go talk to them.  I'd prefer if you cured them from vampirism, but kill them if they refuse to take it.",
    "responses": [
      {
        "text": "I will see if they want to be cured.",
        "topic": "TALK_DONE",
        "effect": [
          { "assign_mission": "MISSION_VAMPIRE_HUNTER_LEADER_CURE_OR_KILL_TARGET" },
          { "math": [ "Vampire_Hunter_Quest_Accepted++" ] },
          { "u_spawn_item": "blood_treatment", "count": 1, "container": "bottle_plastic" }
        ]
      },
      { "text": "<end_talking_bye>", "topic": "TALK_DONE" }
    ]
  },
