    "type": "talk_topic",
    "dynamic_line": [
      "We're what's left of a larger group of vampire hunters, sworn to protect humanity from these monsters that wish to subjugate it.  We would seek more vampires to destroy but <hunter_reason_a>, <hunter_reason_b> and <hunter_reason_c> changed our focus towards staying alive.  We can't fight the blood drinkers if we are all dead."
    ],
    "responses": [
      {
        "text": "Anything I can do to help?",
        "topic": "TALK_VAMPIRE_HUNTER_LEADER_MISSIONS",
        "condition": {
          "and": [
            { "not": { "u_has_trait": "VAMPIRE" } },
            { "math": [ "Vampire_Hunter_Quest_Completed < 3" ] },
            { "math": [ "Vampire_Hunter_Quest_Accepted < 3" ] }
          ]
        }
      },
