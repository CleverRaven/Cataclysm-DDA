  {
    "type": "talk_topic",
    "id": "TALK_SI_HUMAN_AMMO_MERCHANT",
    "//": "Tabani can speak Old English thanks to the phrasebook he has.  His native language is not found on Cataclysm Earth, and so not important.",
    "dynamic_line": "*looks at you as you approach the merchant stall.  As you draw near, he looks down and flips through the book he's carrying and when you get close enough, he smiles broadly.  \"Ah, Wes þu hāl, cuma!  Cumaþ and gesēoþ mīne feorma.\"",
    "responses": [
      {
        "text": "Hello!  Nice to see another person up here.",
        "topic": "TALK_SI_HUMAN_AMMO_MERCHANT_HELLO",
        "condition": { "not": { "compare_string": [ "yes", { "u_val": "u_tried_talking_to_si_human_ammo_merchant" } ] } },
        "effect": { "u_add_var": "u_tried_talking_to_si_human_ammo_merchant", "value": "yes" }
      },
      { "text": "What've you got for trade?", "effect": "start_trade", "topic": "TALK_SI_HUMAN_AMMO_MERCHANT" },
      { "text": "Later.  <end_talking_leave>", "topic": "TALK_DONE" }
    ]
  },
  {
    "type": "talk_topic",
    "id": "TALK_SI_HUMAN_AMMO_MERCHANT_HELLO",
    "dynamic_line": "*smiles and nods in a way you recognize as meaning he has no idea what you're saying.",
    "responses": [
      {
        "text": "Well, fine.  What do you have there?  *you point at the counter*",
        "topic": "TALK_SI_HUMAN_AMMO_MERCHANT_TRADE_EXPLANATION"
      },
      { "text": "Bye.", "topic": "TALK_DONE" }
    ]
  },
  {
    "type": "talk_topic",
