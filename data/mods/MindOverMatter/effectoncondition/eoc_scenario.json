  {
    "type": "effect_on_condition",
    "id": "EOC_MOM_SCEN_HEART_OF_FIRE_ON_CHANNELING_END",
    "eoc_type": "EVENT",
    "required_event": "spellcasting_finish",
    "condition": { "and": [ { "u_has_trait": "SCEN_HEART_OF_FIRE" }, { "math": [ "_success != false" ] } ] },
    "effect": [
